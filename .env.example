# Copy to `.env` for local Compose variable substitution (never commit `.env`).
# Compose loads `.env` from the repo root automatically.

# --- Required: PostgreSQL (generate e.g. `openssl rand -base64 32`) ---
POSTGRES_PASSWORD=

POSTGRES_USER=kanban_app
POSTGRES_DB=kanban_app

# Backend connection (optional override; Compose builds a default from the vars above)
# DATABASE_URL=postgresql://kanban_app:YOUR_PASSWORD@db:5432/kanban_app

# --- Optional: dev-workstation (Compose profile `tools`) ---
# Path to an OpenSSH authorized_keys file (public keys only). Default: ./.dev/authorized_keys
# DEV_WORKSTATION_AUTHORIZED_KEYS=./.dev/authorized_keys
